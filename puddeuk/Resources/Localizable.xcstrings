    "developer.message.p1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I struggled so much to wake up in the morning."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "저는 아침에 일어나는 게 너무 힘들었습니다."
          }
        }
      }
    },
    "developer.message.p2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Instead of hearing the same default alarm every day, I thought it would be more fun to wake up to my own voice, so I created Puddeuk."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "매일 듣는 기본 알람보단 차라리 내 목소리로 시원하게 깨우면 좀 더 재밌지 않을까 해서 퍼뜩을 만들었어요."
          }
        }
      }
    },
    "developer.message.p3" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you have any inconveniences or ideas, please send feedback anytime."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "불편한 점이나 아이디어가 있다면 언제든 후기를 보내주세요."
          }
        }
      }
    },
    "developer.message.p4" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
